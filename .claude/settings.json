{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(pytest *)",
      "Bash(docker compose *)",
      "Bash(docker compose config *)",
      "Bash(docker compose build *)",
      "Bash(docker compose pull *)",
      "Bash(docker compose up *)",
      "Bash(docker compose down *)",
      "Bash(docker compose ps *)",
      "Bash(docker compose logs *)",
      "Bash(docker compose images *)",
      "Bash(curl *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git worktree *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Write(src/**)",
      "Write(pipeline/**)",
      "Write(docs/**)",
      "Write(.claude/agents/**)",
      "Write(.claude/skills/**)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(rm -rf *)",
      "Bash(git push origin main *)"
    ]
  },
  "hooks": {
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gate-validator.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gate-validator.js"
          }
        ]
      }
    ]
  }
}
